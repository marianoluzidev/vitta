rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección de tenants
    // Permitir lectura pública de tenants (necesario para validar si un tenant existe)
    // Permitir escritura solo a usuarios autenticados (el guard requireOwner valida el rol)
    match /tenants/{tenantId} {
      allow read: if true; // Permitir lectura pública
      allow create, update: if request.auth != null; // Solo usuarios autenticados (validado por guard)
      allow delete: if false; // No permitir eliminar (solo desactivar)

      // Staff del tenant: lectura pública para flujo de reserva; escritura solo autenticados
      match /staff/{staffId} {
        allow read: if true;
        allow write: if request.auth != null;
        match /exceptions/{exceptionId} {
          allow read, write: if request.auth != null;
        }
      }
      // Servicios del tenant: lectura pública para reserva; escritura solo autenticados
      match /services/{serviceId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      // Reservas / turnos: lectura y escritura autenticados; create permitido para público (Cloud Functions con admin)
      match /bookings/{bookingId} {
        allow read, write: if request.auth != null;
      }
      // Bloqueos por staff+fecha para transacciones de creación de turnos
      match /locks/{lockId} {
        allow read, write: if request.auth != null;
      }
      // Slots ocupados por staff+fecha (documento agregado para transacciones sin Query en cliente)
      match /slotState/{slotStateId} {
        allow read, write: if request.auth != null;
      }
      // Clientes del tenant: create/update vía Cloud Function para reserva pública; lectura/delete solo auth
      match /clients/{clientId} {
        allow read, create, update, delete: if request.auth != null;
      }
      // Configuración del tenant (ej. booking: ventanas cancelación/reprogramación)
      match /settings/{settingId} {
        allow read, write: if request.auth != null;
      }
    }

    // Colección de owners: permitir lectura si el usuario autenticado está consultando su propio documento
    match /owners/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Solo desde backend/admin
    }
    
    // Reglas por defecto: denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

